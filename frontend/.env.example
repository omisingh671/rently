# Public Vite config only. Values in frontend env files are bundled into JS.
# Do not put database URLs, JWT secrets, mail passwords, or private keys here.

VITE_APP_NAME=Sucasa
VITE_TENANT_SLUG=sucasa
# Optional. Set to lock the public frontend to single property.
# Leave unset for tenant-wide multi-property city selection.
# VITE_PROPERTY_SLUG=home-away-from-home-hyderabad

VITE_API_BASE_URL=http://localhost:4000
VITE_API_PREFIX=/api/v1
