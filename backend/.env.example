# --------------------------------------------------
# Public app origins used for CORS and public links
# --------------------------------------------------

FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# --------------------------------------------------
# Database
# --------------------------------------------------

DATABASE_URL="mysql://root:root@localhost:3306/sucasa?allowPublicKeyRetrieval=true&ssl=false"
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_NAME=sucasa

# --------------------------------------------------
# Application
# --------------------------------------------------

NODE_ENV=development
PORT=4000
API_PREFIX="/api/v1"

# --------------------------------------------------
# Authentication
# --------------------------------------------------

JWT_ACCESS_SECRET="replace_with_a_long_random_access_secret"
JWT_REFRESH_SECRET="replace_with_a_long_random_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --------------------------------------------------
# Email
# --------------------------------------------------

MAIL_USER="noreply@example.com"
MAIL_APP_PASS="replace_with_mail_app_password"
MAIL_FROM="noreply@example.com"
