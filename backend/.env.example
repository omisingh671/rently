# --------------------------------------------------
# Public app origins used for CORS and public links
# --------------------------------------------------

FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# --------------------------------------------------
# Database
# --------------------------------------------------

DATABASE_URL="mysql://root:password@localhost:3306/db_name?allowPublicKeyRetrieval=true&ssl=false"
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=password
DATABASE_NAME=db_name

# Dedicated schema used only by Playwright E2E tests. Do not point this at a
# development, staging, or production database.
E2E_DATABASE_NAME=rently_e2e

# --------------------------------------------------
# Application
# --------------------------------------------------

NODE_ENV=development
PORT=4000
API_PREFIX="/api/v1"

# --------------------------------------------------
# Rate limiting
# --------------------------------------------------

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEV_LOCALHOST_BYPASS=true
AUTH_RATE_LIMIT_MAX=50
PUBLIC_ENQUIRY_RATE_LIMIT_MAX=100
PUBLIC_BOOKING_RATE_LIMIT_MAX=100

# --------------------------------------------------
# Authentication
# --------------------------------------------------

JWT_ACCESS_SECRET="replace_with_a_long_random_access_secret"
JWT_REFRESH_SECRET="replace_with_a_long_random_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --------------------------------------------------
# Seed accounts
# --------------------------------------------------

SEED_SUPER_ADMIN_FULL_NAME="Super Admin"
SEED_SUPER_ADMIN_EMAIL="superadmin@xyz.com"
SEED_SUPER_ADMIN_PASSWORD="SuperAdmin@123"
SEED_SUPER_ADMIN_COUNTRY_CODE="+91"
SEED_SUPER_ADMIN_CONTACT_NUMBER="0000000000"

# --------------------------------------------------
# Email
# --------------------------------------------------

MAIL_USER="noreply@example.com"
MAIL_APP_PASS="replace_with_mail_app_password"
MAIL_FROM="noreply@example.com"
