generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  GUEST
}

enum SessionAudience {
  FRONTEND
  DASHBOARD
}

enum PropertyAssignmentRole {
  ADMIN
  MANAGER
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum UnitStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum RoomProductCategory {
  NIGHTLY
  LONG_STAY
  CORPORATE
}

enum ComfortOption {
  AC
  NON_AC
}

enum RateType {
  NIGHTLY
  WEEKLY
  MONTHLY
}

enum PricingTier {
  STANDARD
  CORPORATE
  SEASONAL
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TaxType {
  PERCENTAGE
  FIXED
}

enum TaxCategory {
  GENERIC
  GST
}

enum TaxScope {
  BOOKING
  ACCOMMODATION
}

enum TaxTargetType {
  ALL
  ROOM
  UNIT
}

enum TaxCalculationMode {
  FLAT
  SLAB_PER_ITEM_NIGHTLY_TARIFF
}

enum TaxDiscountTreatment {
  BEFORE_TAX
}

enum BookingTargetType {
  ROOM
  UNIT
}

enum BookingType {
  SINGLE_TARGET
  MULTI_ROOM
}

enum BookingSource {
  PUBLIC
  WALK_IN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum BookingPaymentPolicy {
  TOKEN_AT_BOOKING
  NO_UPFRONT_PAYMENT
}

enum AdvancePaymentType {
  NONE
  FIXED_AMOUNT
  PERCENTAGE
}

enum BookingPaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  RAZORPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentRefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum BookingRefundRequestStatus {
  REQUESTED
  IN_REVIEW
  REJECTED
  FULFILLED
  CANCELLED
}

enum PaymentPurpose {
  TOKEN
  BALANCE
  FULL_PAYMENT
}

enum PaymentMethod {
  CASH
  UPI_MANUAL
  BANK_TRANSFER
  CARD_POS
  MANUAL
  ONLINE_GATEWAY
}

enum BillingDocumentType {
  INVOICE
  RECEIPT
  CREDIT_NOTE
  DEBIT_NOTE
}

enum BillingDocumentStatus {
  DRAFT
  ISSUED
  CANCELLED
  VOID
}

enum SideEffectJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum EmailDeliveryType {
  PASSWORD_RESET
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationEventKey {
  BOOKING_CREATED
  BOOKING_CANCELLED
  PAYMENT_SUCCEEDED
  REFUND_SUCCEEDED
  USER_REGISTERED
  BOOKING_CHECKED_IN
  BOOKING_CHECKED_OUT
}

enum NotificationSettingScope {
  GLOBAL
  PROPERTY
}

enum NotificationSettingState {
  USE_GLOBAL
  ENABLED
  DISABLED
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum MaintenanceTargetType {
  PROPERTY
  UNIT
  ROOM
}

enum RoomHousekeepingStatus {
  DIRTY
  CLEANING
  CLEAN
  INSPECTED
}

enum BookingOperationEventType {
  CHECK_IN
  CHECK_OUT
  NO_SHOW
  ROOM_ASSIGNMENT
  ROOM_MOVE
  STATUS_CORRECTION
  BALANCE_OVERRIDE
  MAINTENANCE_CONFLICT
  FOLIO_CHARGE
  FOLIO_CHARGE_VOID
  STAY_EXTENSION
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum FolioChargeType {
  INCIDENTAL
  PENALTY
  EXTENSION
  ADJUSTMENT
}

enum FolioChargeStatus {
  ACTIVE
  VOID
}

/**
 * =========================
 * USER & AUTH
 * =========================
 */

model User {
  id       String @id @default(uuid())
  fullName String
  email    String @unique

  countryCode   String? @db.VarChar(8)
  contactNumber String? @db.VarChar(20)

  createdByUserId String?
  passwordHash    String
  role            UserRole @default(GUEST)

  createdBy                  User?                  @relation("UserCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdUsers               User[]                 @relation("UserCreator")
  sessions                   Session[]
  resetTokens                PasswordResetToken[]
  emailDeliveryJobs          EmailDeliveryJob[]
  bookings                   Booking[]
  bookingRefundRequests      BookingRefundRequest[]
  reviewedRefundRequests     BookingRefundRequest[] @relation("RefundRequestReviewedBy")
  payments                   Payment[]
  refunds                    PaymentRefund[]
  paymentsReceived           Payment[]              @relation("PaymentReceivedBy")
  bookingStatusHistory       BookingStatusHistory[] @relation("BookingStatusActor")
  quotes                     QuoteRequest[]
  propertyAssignments        PropertyAssignment[]   @relation("AssignedUser")
  createdPropertyAssignments PropertyAssignment[]   @relation("AssignmentCreatedBy")
  createdProperties          Property[]             @relation("PropertyCreatedBy")
  createdMaintenanceBlocks   MaintenanceBlock[]     @relation("MaintenanceCreatedBy")
  assignedMaintenanceBlocks  MaintenanceBlock[]     @relation("MaintenanceAssignedTo")
  bookingOperationEvents     BookingOperationEvent[]
  housekeepingEvents         RoomHousekeepingEvent[]
  createdFolioCharges        BookingFolioCharge[]    @relation("FolioChargeCreatedBy")
  voidedFolioCharges         BookingFolioCharge[]    @relation("FolioChargeVoidedBy")
  notificationSettingAudits  NotificationSettingAudit[]
  bookingPolicyAudits       BookingPolicyAudit[]

  isActive           Boolean @default(true)
  mustChangePassword Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique @db.VarChar(512)
  audience     SessionAudience @default(DASHBOARD)
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([audience])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model EmailDeliveryJob {
  id                  String              @id @default(uuid())
  type                EmailDeliveryType
  status              SideEffectJobStatus @default(PENDING)
  userId              String
  recipient           String
  appUrl              String
  tokenTtlMinutes     Int                 @default(15)
  attemptCount        Int                 @default(0)
  maxAttempts         Int                 @default(3)
  lastError           String?             @db.Text
  correlationId       String?             @db.VarChar(128)
  processingStartedAt DateTime?
  sentAt              DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
  @@index([userId, createdAt])
  @@map("email_delivery_jobs")
}

model NotificationGlobalSetting {
  id        String               @id @default(uuid())
  eventKey  NotificationEventKey
  channel   NotificationChannel
  enabled   Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([eventKey, channel])
  @@map("notification_global_settings")
}

model PropertyNotificationOverride {
  id         String                   @id @default(uuid())
  propertyId String
  eventKey   NotificationEventKey
  channel    NotificationChannel
  state      NotificationSettingState
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, eventKey, channel])
  @@index([propertyId])
  @@map("property_notification_overrides")
}

model NotificationSettingAudit {
  id            String                   @id @default(uuid())
  actorUserId   String
  scope         NotificationSettingScope
  propertyId    String?
  eventKey      NotificationEventKey
  channel       NotificationChannel
  previousState NotificationSettingState?
  nextState     NotificationSettingState
  correlationId String?                  @db.VarChar(128)
  createdAt     DateTime                 @default(now())

  actor    User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([propertyId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("notification_setting_audits")
}

model NotificationDeliveryJob {
  id                  String                  @id @default(uuid())
  idempotencyKey      String                  @unique @db.VarChar(191)
  eventKey            NotificationEventKey
  channel             NotificationChannel
  propertyId          String?
  recipient           String
  payload             Json
  status              SideEffectJobStatus     @default(PENDING)
  attemptCount        Int                     @default(0)
  maxAttempts         Int                     @default(3)
  lastError           String?                 @db.Text
  providerMessageId   String?
  correlationId       String?                 @db.VarChar(128)
  processingStartedAt DateTime?
  sentAt              DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([propertyId, createdAt])
  @@index([eventKey, createdAt])
  @@map("notification_delivery_jobs")
}

/**
 * =========================
 * INVENTORY
 * =========================
 */

model Tenant {
  id                  String       @id @default(uuid())
  name                String
  slug                String       @unique
  primaryDomain       String?      @unique
  status              TenantStatus @default(ACTIVE)
  brandName           String
  logoUrl             String?
  primaryColor        String       @default("#4f46e5")
  secondaryColor      String       @default("#f59e0b")
  supportEmail        String?
  supportPhone        String?
  defaultCurrency     String       @default("INR")
  timezone            String       @default("Asia/Kolkata")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  billingDocuments BillingDocument[]

  @@map("tenants")
}

model Property {
  id              String @id @default(uuid())
  tenantId        String
  slug            String
  name            String
  address         String
  city            String
  state           String
  createdByUserId String
  supportEmail    String?
  supportPhone    String?
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)

  isActive Boolean        @default(true)
  status   PropertyStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy         User                 @relation("PropertyCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  units             Unit[]
  amenities         PropertyAmenity[]
  roomProducts      RoomProduct[]
  roomPricing       RoomPricing[]
  bookings          Booking[]
  bookingPolicy     PropertyBookingPolicy?
  bookingRefundRequests BookingRefundRequest[]
  inventoryLocks    InventoryLock[]
  payments          Payment[]
  refunds           PaymentRefund[]
  quoteRequests     QuoteRequest[]
  enquiries         Enquiry[]
  assignments       PropertyAssignment[]
  maintenanceBlocks MaintenanceBlock[]
  bookingOperationEvents BookingOperationEvent[]
  folioCharges      BookingFolioCharge[]
  housekeepingEvents RoomHousekeepingEvent[]
  taxes             Tax[]
  coupons           Coupon[]
  galleries         Gallery[]
  billingSetting    BillingSetting?
  billingDocuments  BillingDocument[]
  notificationOverrides PropertyNotificationOverride[]
  notificationSettingAudits NotificationSettingAudit[]
  notificationDeliveryJobs NotificationDeliveryJob[]
  bookingPolicyAudits BookingPolicyAudit[]

  @@unique([tenantId, name, city, state])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("properties")
}

model PropertyBookingPolicy {
  id                  String             @id @default(uuid())
  propertyId          String             @unique
  advancePaymentType  AdvancePaymentType @default(FIXED_AMOUNT)
  advancePaymentValue Decimal            @default(10)
  tokenRefundable     Boolean            @default(false)
  checkInTime         String             @default("12:00")
  checkOutTime        String             @default("11:00")
  pendingPaymentExpiryMinutes Int        @default(15)
  cancellationRules   Json
  refundRules         Json
  earlyCheckInRules   Json?
  earlyCheckoutRules  Json
  lateCheckoutRules   Json?
  downgradeRules      Json?
  noShowRules         Json
  guestPolicyText     String             @db.Text
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  audits   BookingPolicyAudit[]

  @@map("property_booking_policies")
}

model BookingPolicyAudit {
  id          String   @id @default(uuid())
  policyId    String
  propertyId  String
  actorUserId String
  version     Int
  previousData Json
  nextData     Json
  createdAt   DateTime @default(now())

  policy   PropertyBookingPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  property Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  actor    User                  @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([propertyId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("booking_policy_audits")
}

model Unit {
  id         String @id @default(uuid())
  propertyId String
  unitNumber String
  floor      Int

  isActive Boolean    @default(true)
  status   UnitStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property          Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms             Room[]
  pricing           RoomPricing[]
  amenities         UnitAmenity[]
  maintenanceBlocks MaintenanceBlock[]
  galleries         Gallery[]

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@map("units")
}

model Room {
  id           String     @id @default(uuid())
  unitId       String
  name         String
  number       String
  hasAC        Boolean    @default(false)
  maxOccupancy Int        @default(2)
  status       RoomStatus @default(AVAILABLE)
  housekeepingStatus RoomHousekeepingStatus @default(INSPECTED)
  isActive     Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  amenities         RoomAmenity[]
  pricing           RoomPricing[]
  maintenanceBlocks MaintenanceBlock[]
  housekeepingEvents RoomHousekeepingEvent[]
  galleries         Gallery[]

  @@unique([unitId, number])
  @@index([unitId])
  @@map("rooms")
}

/**
 * =========================
 * PRODUCTS & PRICING
 * =========================
 */

model RoomProduct {
  id         String              @id @default(uuid())
  propertyId String
  name       String
  occupancy  Int
  hasAC      Boolean
  category   RoomProductCategory

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  pricing  RoomPricing[]
  quotes   QuoteRequest[]

  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("room_products")
}

model RoomPricing {
  id           String      @id @default(uuid())
  propertyId   String
  roomId       String?
  unitId       String?
  productId    String
  rateType     RateType    @default(NIGHTLY)
  pricingTier  PricingTier @default(STANDARD)
  minNights    Int         @default(1)
  maxNights    Int?
  taxInclusive Boolean     @default(false)
  price        Decimal
  validFrom    DateTime
  validTo      DateTime?
  createdAt    DateTime    @default(now())

  property Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room     Room?       @relation(fields: [roomId], references: [id], map: "fk_room_pricing_room")
  unit     Unit?       @relation(fields: [unitId], references: [id], map: "fk_room_pricing_unit")
  product  RoomProduct @relation(fields: [productId], references: [id], map: "fk_room_pricing_product")

  @@index([propertyId])
  @@index([roomId])
  @@index([unitId])
  @@index([productId])
  @@index([validFrom, validTo])
  @@map("room_pricing")
}

/**
 * =========================
 * QUOTES & BOOKINGS
 * =========================
 */

model QuoteRequest {
  id         String            @id @default(uuid())
  propertyId String
  userId     String?
  productId  String?
  targetType BookingTargetType
  unitId     String?
  roomId     String?

  checkIn  DateTime
  checkOut DateTime
  status   LeadStatus @default(NEW)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User?        @relation(fields: [userId], references: [id], map: "fk_quote_user")
  product  RoomProduct? @relation(fields: [productId], references: [id], map: "fk_quote_product")

  @@index([propertyId])
  @@index([userId])
  @@map("quote_requests")
}

model Booking {
  id            String            @id @default(uuid())
  bookingRef    String            @unique
  propertyId    String
  userId        String
  productId     String?
  bookingType   BookingType       @default(SINGLE_TARGET)
  source        BookingSource     @default(PUBLIC)
  targetType    BookingTargetType
  unitId        String?
  roomId        String?
  guestCount    Int               @default(1)
  comfortOption ComfortOption

  guestNameSnapshot    String
  guestEmailSnapshot   String
  guestContactSnapshot String?
  targetLabel          String
  productName          String
  pricePerNight        Decimal

  checkIn            DateTime
  checkOut           DateTime
  status             BookingStatus        @default(PENDING)
  version            Int                  @default(1)
  checkedInAt        DateTime?
  checkedOutAt       DateTime?
  noShowAt           DateTime?
  identityVerifiedAt DateTime?
  identityDocumentType String?             @db.VarChar(50)
  identityDocumentReference String?        @db.VarChar(100)
  subtotalAmount     Decimal              @default(0)
  taxableAmount      Decimal              @default(0)
  taxAmount          Decimal              @default(0)
  taxBreakdown       Json?
  totalAmount        Decimal
  paymentStatus      BookingPaymentStatus @default(PENDING)
  paymentPolicy      BookingPaymentPolicy @default(TOKEN_AT_BOOKING)
  upfrontAmount      Decimal              @default(10)
  paymentExpiresAt   DateTime?
  policySnapshot     Json?
  couponId           String?
  discountAmount     Decimal              @default(0)
  internalNotes      String?              @db.Text
  cancellationReason String?              @db.Text
  cancelledAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  property       Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], map: "fk_booking_user")
  coupon         Coupon?                @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items          BookingItem[]
  payments       Payment[]
  refunds        PaymentRefund[]
  refundRequests BookingRefundRequest[]
  statusHistory  BookingStatusHistory[]
  operationEvents BookingOperationEvent[]
  folioCharges   BookingFolioCharge[]
  housekeepingEvents RoomHousekeepingEvent[]
  inventoryLocks InventoryLock[]
  billingDocuments BillingDocument[]

  @@index([propertyId])
  @@index([userId])
  @@index([bookingRef])
  @@index([roomId, checkIn, checkOut])
  @@index([unitId, checkIn, checkOut])
  @@index([status, checkIn, checkOut])
  @@index([status, paymentExpiresAt])
  @@index([propertyId, checkedInAt])
  @@index([propertyId, checkedOutAt])
  @@map("bookings")
}

model InventoryLock {
  id              String            @id @default(uuid())
  lockToken       String
  propertyId      String
  targetType      BookingTargetType
  unitId          String?
  roomId          String?
  checkIn         DateTime
  checkOut        DateTime
  expiresAt       DateTime
  releasedAt      DateTime?
  bookingId       String?
  createdByUserId String?
  createdAt       DateTime          @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([lockToken])
  @@index([propertyId, expiresAt, releasedAt])
  @@index([roomId, checkIn, checkOut])
  @@index([unitId, checkIn, checkOut])
  @@map("inventory_locks")
}

model BookingItem {
  id            String            @id @default(uuid())
  bookingId     String
  productId     String?
  targetType    BookingTargetType
  unitId        String?
  roomId        String?
  guestCount    Int               @default(1)
  comfortOption ComfortOption

  targetLabel    String
  productName    String
  capacity       Int
  pricePerNight  Decimal
  pricingId      String?
  subtotalAmount Decimal @default(0)
  discountAmount Decimal @default(0)
  taxableAmount  Decimal @default(0)
  taxAmount      Decimal @default(0)
  taxBreakdown   Json?
  totalAmount    Decimal
  finalAmount    Decimal @default(0)

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([roomId])
  @@index([unitId])
  @@map("booking_items")
}

model BookingStatusHistory {
  id          String         @id @default(uuid())
  bookingId   String
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  actorUserId String?
  note        String?        @db.Text
  createdAt   DateTime       @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor   User?   @relation("BookingStatusActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([actorUserId])
  @@map("booking_status_history")
}

model BookingOperationEvent {
  id          String                    @id @default(uuid())
  bookingId   String
  propertyId  String
  actorUserId String?
  eventType   BookingOperationEventType
  note        String?                   @db.Text
  metadata    Json?
  createdAt   DateTime                  @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([propertyId, eventType, createdAt])
  @@index([actorUserId, createdAt])
  @@map("booking_operation_events")
}

model BookingFolioCharge {
  id              String            @id @default(uuid())
  bookingId       String
  propertyId      String
  createdByUserId String
  voidedByUserId  String?
  type            FolioChargeType
  status          FolioChargeStatus @default(ACTIVE)
  description     String            @db.VarChar(255)
  amount          Decimal
  note            String?           @db.Text
  metadata        Json?
  voidReason      String?           @db.Text
  voidedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdBy User     @relation("FolioChargeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  voidedBy  User?    @relation("FolioChargeVoidedBy", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  billingDocuments BillingDocument[]

  @@index([bookingId, status, createdAt])
  @@index([propertyId, createdAt])
  @@index([createdByUserId])
  @@index([voidedByUserId])
  @@map("booking_folio_charges")
}

model Payment {
  id                String          @id @default(uuid())
  bookingId         String
  propertyId        String
  userId            String
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  purpose           PaymentPurpose  @default(TOKEN)
  method            PaymentMethod   @default(MANUAL)
  amount            Decimal
  currency          String          @default("INR") @db.VarChar(3)
  idempotencyKey    String          @unique
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?
  failureCode       String?
  failureMessage    String?
  metadata          Json?
  note              String?         @db.Text
  receivedByUserId  String?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  receivedBy User?    @relation("PaymentReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  billingDocuments BillingDocument[]
  refunds PaymentRefund[]

  @@unique([provider, providerPaymentId])
  @@index([bookingId])
  @@index([propertyId])
  @@index([userId])
  @@index([receivedByUserId])
  @@index([status, createdAt])
  @@map("payments")
}

model PaymentRefund {
  id                   String              @id @default(uuid())
  bookingId            String
  paymentId            String
  propertyId           String
  userId               String
  refundRequestId      String?
  provider             PaymentProvider
  status               PaymentRefundStatus @default(PENDING)
  method               PaymentMethod       @default(MANUAL)
  amount               Decimal
  currency             String              @default("INR") @db.VarChar(3)
  reason               String              @db.Text
  idempotencyKey       String              @unique
  providerRefundId     String?
  providerRefundStatus String?
  metadata             Json?
  processedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refundRequest BookingRefundRequest? @relation(fields: [refundRequestId], references: [id], onDelete: SetNull)

  @@unique([provider, providerRefundId])
  @@index([bookingId])
  @@index([paymentId])
  @@index([propertyId])
  @@index([userId])
  @@index([refundRequestId])
  @@index([status, createdAt])
  @@map("payment_refunds")
}

model BookingRefundRequest {
  id               String                     @id @default(uuid())
  bookingId        String
  propertyId       String
  userId           String
  status           BookingRefundRequestStatus @default(REQUESTED)
  reason           String                     @db.Text
  adminNote        String?                    @db.Text
  reviewedByUserId String?
  reviewedAt       DateTime?
  fulfilledAt      DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  booking    Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?           @relation("RefundRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  refunds    PaymentRefund[]

  @@index([bookingId, status])
  @@index([propertyId, status, createdAt])
  @@index([userId, status])
  @@index([reviewedByUserId])
  @@map("booking_refund_requests")
}

model BillingSetting {
  id                   String @id @default(uuid())
  propertyId           String @unique
  legalName            String?
  gstin                String?
  pan                  String?
  billingAddress       String? @db.Text
  invoicePrefix        String @default("INV-")
  receiptPrefix        String @default("RCT-")
  creditNotePrefix     String @default("CN-")
  debitNotePrefix      String @default("DN-")
  invoiceSequence      Int    @default(0)
  receiptSequence      Int    @default(0)
  creditNoteSequence   Int    @default(0)
  debitNoteSequence    Int    @default(0)
  footerNotes          String? @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("billing_settings")
}

model BillingDocument {
  id               String                @id @default(uuid())
  documentKey      String                @unique
  type             BillingDocumentType
  status           BillingDocumentStatus @default(ISSUED)
  documentNumber   String
  bookingId        String
  paymentId        String?
  folioChargeId    String?
  propertyId       String
  tenantId         String?
  subtotal         Decimal               @default(0)
  discount         Decimal               @default(0)
  taxable          Decimal               @default(0)
  tax              Decimal               @default(0)
  total            Decimal               @default(0)
  paid             Decimal               @default(0)
  balance          Decimal               @default(0)
  guestSnapshot    Json
  propertySnapshot Json
  tenantSnapshot   Json?
  bookingSnapshot  Json
  priceSnapshot    Json
  taxSnapshot      Json?
  paymentSnapshot  Json?
  lineItems        Json
  notes            String?               @db.Text
  pdfUrl           String?
  pdfStatus        SideEffectJobStatus @default(PENDING)
  pdfAttemptCount  Int                 @default(0)
  pdfMaxAttempts   Int                 @default(3)
  pdfLastError     String?             @db.Text
  pdfCorrelationId String?             @db.VarChar(128)
  pdfProcessingStartedAt DateTime?
  pdfRenderedAt    DateTime?
  issuedAt         DateTime?
  voidedAt         DateTime?
  voidReason       String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  folioCharge BookingFolioCharge? @relation(fields: [folioChargeId], references: [id], onDelete: SetNull)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([propertyId, documentNumber])
  @@index([propertyId, type, status, issuedAt])
  @@index([tenantId])
  @@index([bookingId])
  @@index([paymentId])
  @@index([folioChargeId])
  @@map("billing_documents")
}

/**
 * =========================
 * AMENITIES
 * =========================
 */

model Amenity {
  id   String  @id @default(uuid())
  name String  @unique
  icon String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  propertyAmenities PropertyAmenity[]
  unitAmenities     UnitAmenity[]
  roomAmenities     RoomAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  propertyId String
  amenityId  String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade, map: "fk_property_amenity_property")
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade, map: "fk_property_amenity_amenity")

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

model UnitAmenity {
  unitId    String
  amenityId String

  unit    Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade, map: "fk_unit_amenity_unit")
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade, map: "fk_unit_amenity_amenity")

  @@id([unitId, amenityId])
  @@index([amenityId])
  @@map("unit_amenities")
}

model RoomAmenity {
  roomId    String
  amenityId String

  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade, map: "fk_room_amenity_room")
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade, map: "fk_room_amenity_amenity")

  @@id([roomId, amenityId])
  @@map("room_amenities")
}

/**
 * =========================
 * ENQUIRIES
 * =========================
 */

model Enquiry {
  id            String @id @default(uuid())
  propertyId    String
  name          String
  email         String
  contactNumber String
  message       String

  source String?
  status LeadStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("enquiries")
}

model PropertyAssignment {
  id                     String                 @id @default(uuid())
  propertyId             String
  userId                 String
  role                   PropertyAssignmentRole
  assignedByUserId       String
  primaryAdminPropertyId String?                @unique
  createdAt              DateTime               @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation("AssignedUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User     @relation("AssignmentCreatedBy", fields: [assignedByUserId], references: [id], onDelete: Restrict)

  @@unique([propertyId, userId])
  @@index([userId])
  @@index([propertyId, role])
  @@map("property_assignments")
}

model MaintenanceBlock {
  id              String                @id @default(uuid())
  propertyId      String
  unitId          String?
  roomId          String?
  targetType      MaintenanceTargetType
  reason          String?
  status          MaintenanceStatus   @default(SCHEDULED)
  priority        MaintenancePriority @default(MEDIUM)
  assignedToUserId String?
  resolutionNote  String?             @db.Text
  resolvedAt      DateTime?
  emergencyOverride Boolean           @default(false)
  startDate       DateTime
  endDate         DateTime
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit      Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdBy User     @relation("MaintenanceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedTo User?   @relation("MaintenanceAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([propertyId, status, priority])
  @@index([assignedToUserId, status])
  @@index([startDate, endDate])
  @@map("maintenance_blocks")
}

model RoomHousekeepingEvent {
  id          String                 @id @default(uuid())
  propertyId  String
  roomId      String
  actorUserId String
  bookingId   String?
  fromStatus  RoomHousekeepingStatus
  toStatus    RoomHousekeepingStatus
  note        String?                @db.Text
  createdAt   DateTime               @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  actor    User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt])
  @@index([propertyId, toStatus, createdAt])
  @@index([actorUserId, createdAt])
  @@index([bookingId])
  @@map("room_housekeeping_events")
}

model Tax {
  id                String               @id @default(uuid())
  propertyId        String
  name              String
  rate              Decimal
  taxType           TaxType              @default(PERCENTAGE)
  category          TaxCategory          @default(GENERIC)
  scope             TaxScope             @default(BOOKING)
  targetType        TaxTargetType        @default(ALL)
  calculationMode   TaxCalculationMode   @default(FLAT)
  discountTreatment TaxDiscountTreatment @default(BEFORE_TAX)
  minTariff         Decimal?
  maxTariff         Decimal?
  validFrom         DateTime?
  validTo           DateTime?
  priority          Int                  @default(0)
  appliesTo         String               @default("ALL")
  isRefundable      Boolean              @default(true)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, category, scope, targetType, isActive])
  @@map("taxes")
}

model Coupon {
  id            String       @id @default(uuid())
  propertyId    String
  code          String
  name          String
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Decimal
  maxUses       Int?
  usedCount     Int          @default(0)
  minNights     Int?
  minAmount     Decimal?
  validFrom     DateTime
  validTo       DateTime?
  isActive      Boolean      @default(true)
  oncePerUser   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([propertyId, code])
  @@index([propertyId])
  @@map("coupons")
}

model Gallery {
  id         String   @id @default(uuid())
  propertyId String
  unitId     String?
  roomId     String?
  url        String   @db.VarChar(500)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  room     Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([unitId])
  @@index([roomId])
  @@map("galleries")
}
